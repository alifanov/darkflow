generator client {
  provider = "prisma-client-js"
  // Host node may run under Rosetta (reports x64) while the runtime needs the
  // arm64 engine — bundle both macOS engines so `make web` works either way.
  // Docker (linux) build picks its engine via "native".
  binaryTargets = ["native", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String    @id @default(cuid())
  name          String
  slug          String?
  domain        String?
  localPath     String?
  repoUrl       String    @unique
  branch        String    @default("main")
  active        Boolean   @default(true)
  language      String    @default("English")
  mergeStrategy String    @default("pr")
  minPriority   String    @default("medium")
  modules            String[]
  maxConcurrent      Int       @default(3)
  posthogProjectId   String?
  obsTool            String?
  obsUrl             String?
  darkflowVersion    String?
  lastSyncedAt       DateTime?
  settingsUpdatedAt  DateTime?
  createdAt     DateTime  @default(now())

  issues             Issue[]
  analyticsSnapshots AnalyticsSnapshot[]
  securityStatus     SecurityStatus?
  architectureStatus ArchitectureStatus?
  routineLogs        RoutineLog[]
  routineConfigs     RoutineConfig[]
  workerStatus       WorkerStatus?
  commits            Commit[]
  alerts             ProjectAlert[]
  emails             Email[]
}

model Email {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uid       String?            // IMAP UID (volatile, informational only)
  messageId String             // dedupe key: RFC Message-ID, or "uid:<uid>" if absent
  fromAddr  String
  subject   String
  body      String   @db.Text
  seen      Boolean  @default(false)
  sentAt    DateTime?          // parsed Date header
  createdAt DateTime @default(now())

  @@unique([projectId, messageId])
  @@index([projectId, sentAt])
}

model Issue {
  id              String    @id @default(cuid())
  projectId       String
  number          Int
  title           String
  body            String?
  state           String    @default("open")
  url             String?
  status          String    @default("none")
  priority        String?
  source          String?
  action          String?
  needsHuman      Boolean   @default(false)
  comments        Json?
  // Lifecycle timestamps. createdAt is set once on POST /api/tasks; closedAt
  // is set when state transitions to "closed". Nullable for old rows imported
  // before this field existed.
  createdAt       DateTime?
  closedAt        DateTime?
  updatedAt       DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([state])
  @@index([projectId, state])
  @@index([projectId, needsHuman])
  @@index([createdAt])
  @@index([closedAt])
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  projectId   String
  usersTotal  Int?
  visitors7d  Int?
  revenue7d   Float?
  adsSpend7d  Float?
  currency    String   @default("USD")
  capturedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, capturedAt(sort: Desc)])
}

model SecurityStatus {
  id           String   @id @default(cuid())
  projectId    String   @unique
  openIssues   Int      @default(0)
  criticalOpen Int      @default(0)
  status       String   @default("ok")
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ArchitectureStatus {
  id         String   @id @default(cuid())
  projectId  String   @unique
  openIssues Int      @default(0)
  status     String   @default("ok")
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RoutineLog {
  id          String   @id @default(cuid())
  projectId   String
  routine     String
  summary     String
  output      String?
  model       String?
  costUsd     Float?
  totalTokens Int?
  timestamp   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp(sort: Desc)])
}

model RoutineConfig {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  cron           String?
  model          String?
  engine         String?  @default("claude")
  enabled        Boolean  @default(true)
  permissionMode String?
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

model Commit {
  id          String   @id @default(cuid())
  projectId   String
  sha         String
  message     String
  author      String
  email       String?
  committedAt DateTime
  url         String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sha])
  @@index([projectId, committedAt(sort: Desc)])
}

model WorkerStatus {
  id             String    @id @default(cuid())
  projectId      String    @unique
  routine        String?
  status         String    @default("idle")
  configSyncedAt DateTime?
  updatedAt      DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectAlert {
  id        String   @id @default(cuid())
  projectId String
  key       String
  title     String
  severity  String   @default("warning")
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, severity])
}

model Settings {
  id       String  @id @default("global")
  ghToken  String?

  // Global worker status — there is one worker servicing every project, so its
  // version and liveness are machine-level, reported on each heartbeat.
  workerVersion  String?
  workerLastSeen DateTime?
  workerRoutine  String?
}
