generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String    @id @default(cuid())
  name          String
  repoUrl       String    @unique
  branch        String    @default("main")
  language      String    @default("English")
  mergeStrategy String    @default("pr")
  modules       String[]
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())

  issues             Issue[]
  analyticsSnapshots AnalyticsSnapshot[]
  securityStatus     SecurityStatus?
  architectureStatus ArchitectureStatus?
  routineLogs        RoutineLog[]
  routineConfigs     RoutineConfig[]
  workerStatus       WorkerStatus?
  commits            Commit[]
  alerts             ProjectAlert[]
}

model Issue {
  id              String    @id @default(cuid())
  projectId       String
  number          Int
  title           String
  body            String?
  state           String    @default("open")
  url             String?
  status          String    @default("none")
  pendingStatus   String?
  pendingStatusAt DateTime?
  priority        String?
  source          String?
  updatedAt       DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  projectId   String
  usersTotal  Int?
  visitors7d  Int?
  revenue7d   Float?
  adsSpend7d  Float?
  currency    String   @default("USD")
  capturedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SecurityStatus {
  id           String   @id @default(cuid())
  projectId    String   @unique
  openIssues   Int      @default(0)
  criticalOpen Int      @default(0)
  status       String   @default("ok")
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ArchitectureStatus {
  id         String   @id @default(cuid())
  projectId  String   @unique
  openIssues Int      @default(0)
  status     String   @default("ok")
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RoutineLog {
  id        String   @id @default(cuid())
  projectId String
  routine   String
  summary   String
  output    String?
  timestamp DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RoutineConfig {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  cron           String?
  model          String?
  enabled        Boolean  @default(true)
  permissionMode String?
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

model Commit {
  id          String   @id @default(cuid())
  projectId   String
  sha         String
  message     String
  author      String
  email       String?
  committedAt DateTime
  url         String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sha])
  @@index([projectId, committedAt(sort: Desc)])
}

model WorkerStatus {
  id        String   @id @default(cuid())
  projectId String   @unique
  routine   String?
  status    String   @default("idle")
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectAlert {
  id        String   @id @default(cuid())
  projectId String
  key       String
  title     String
  severity  String   @default("warning")
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, severity])
}
