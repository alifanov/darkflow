# Connection string for the webapp running as a host process.
# Postgres is published on localhost:5432 by `docker compose up -d` (db service).
# Password must match POSTGRES_PASSWORD in the repo-root .env (default: darkflow).
DATABASE_URL="postgresql://darkflow:darkflow@localhost:5432/darkflow"

# Optional: path/name of the cmux CLI used by the "Fix in cmux" button.
# Defaults to `cmux` on PATH. Install the CLI from the cmux app, or set this to the
# full path of the shim if it isn't on PATH.
# CMUX_BIN="cmux"
